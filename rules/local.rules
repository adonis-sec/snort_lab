alert icmp any any -> $HOME_NET any (msg:"Ping detected"; sid:1000001; rev:1;)

alert tcp any any -> $HOME_NET any (flags:S; msg:"SYN Scan detected"; sid:1000002; rev:1;)

alert tcp any any -> $HOME_NET 3389 (msg:"RDP Brute Force Attempt"; detection_filter:track by_src, count 5, seconds 60; sid:1000003; rev:1;)

alert tcp any any -> $HOME_NET 80 (content:"/admin"; http_uri; msg:"Admin access attempt"; sid:1000004; rev:1;)

alert tcp any any -> $HOME_NET 80 (content:"' OR 1=1"; nocase; msg:"SQL Injection attempt"; sid:1000005; rev:1;)
